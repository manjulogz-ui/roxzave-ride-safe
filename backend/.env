DATABASE_URL=sqlite+aiosqlite:///./roxzave.db
DATABASE_URL_SYNC=sqlite:///./roxzave.db
USE_SQLITE=true
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=dev-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET_KEY=dev-refresh-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,capacitor://localhost,http://localhost
ENVIRONMENT=development
